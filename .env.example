# -----------------------------------------------------------------------------
# CorpersLink Web — Environment Configuration
# Copy this file to `.env` (and/or `.env.development` / `.env.production`) and
# adjust values as needed. See README.md > "Environment Variables" for details.
# -----------------------------------------------------------------------------

# Base URL of the real CorpersLink REST API.
# Ignored while VITE_USE_MOCK_API=true.
VITE_API_BASE_URL=https://corpslink-api.test/api/v1

# When "true", every API call is served by the in-memory mock backend
# (src/core/api/mock). No network access or backend server is required.
# Set to "false" to talk to the real backend at VITE_API_BASE_URL.
VITE_USE_MOCK_API=true

# Simulated network latency (in milliseconds) added to every mock API call,
# so loading/skeleton states behave the same as they would in production.
VITE_MOCK_LATENCY_MS=450

# Request timeout (ms) applied to the axios client, real or mocked.
VITE_API_TIMEOUT_MS=15000
